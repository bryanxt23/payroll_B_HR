{
  "name": "inventorysales-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright end-to-end tests for the InventorySales app (Sales, Inventory, Dashboard, Reports).",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:dashboard": "playwright test tests/dashboard.spec.ts",
    "test:inventory": "playwright test tests/inventory.spec.ts",
    "test:sales": "playwright test tests/sales.spec.ts",
    "test:reports": "playwright test tests/reports.spec.ts",
    "report": "playwright show-report",
    "install:browsers": "playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
